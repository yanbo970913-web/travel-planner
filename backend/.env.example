# ---- 複製成 .env 後填入實際值 ----
ENV=development

# 資料庫（本機用 docker-compose 預設；Render 會自動注入 DATABASE_URL）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/travel

# JWT 簽章密鑰（產生方式： python -c "import secrets; print(secrets.token_urlsafe(48))" ）
JWT_SECRET=請換成隨機長字串

# NVIDIA AI（稍後填入真正金鑰）
NVIDIA_API_KEY=你的_NVIDIA_API_KEY
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Email 寄信（留空則自動退回 dev fallback：把驗證連結印到 log）
# 範例（Gmail 需用「應用程式密碼」）：
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youraccount@gmail.com
# SMTP_PASSWORD=應用程式密碼
# EMAIL_FROM=youraccount@gmail.com

# 前端網址（信件連結與 CORS 來源；多個用逗號分隔）
FRONTEND_URL=http://localhost:5173
