# ---- 複製成 .env 後填入實際值 ----
ENV=development

# 資料庫
# 本機：用 docker-compose 的預設值即可。
# 雲端（Neon 永久免費）：貼上 Neon 的連線字串，例如：
#   postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/travel

# JWT 簽章密鑰（產生方式： python -c "import secrets; print(secrets.token_urlsafe(48))" ）
JWT_SECRET=請換成隨機長字串

# ---- AI 引擎 ----
# 主力：Groq（免費、極快、雲端穩定）。申請：https://console.groq.com
GROQ_API_KEY=你的_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# 次要：NVIDIA（選填，可留空）
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Email 寄信（留空則自動退回 dev fallback：把驗證連結印到 log）
# 範例（Gmail 需用「應用程式密碼」）：
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youraccount@gmail.com
# SMTP_PASSWORD=應用程式密碼
# EMAIL_FROM=youraccount@gmail.com

# 前端網址（信件連結與 CORS 來源；多個用逗號分隔）
FRONTEND_URL=http://localhost:5173

# 天氣預報使用 Open-Meteo + OpenStreetMap Nominatim，皆免費免金鑰，無需設定。
